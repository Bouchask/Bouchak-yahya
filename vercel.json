{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "installCommand": "npm install vite@7.3.6 --save-dev --save-exact && npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "(.*)",
      "destination": "/index.html"
    }
  ]
}
